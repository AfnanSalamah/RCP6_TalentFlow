# ─── TalentFlow Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# Never commit your actual .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./talentflow.db
# For PostgreSQL: postgresql://user:password@localhost:5432/talentflow

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
RESET_TOKEN_EXPIRE_MINUTES=30

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── OpenAI (optional — leave empty for mock AI responses) ─────────────────────
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=TalentFlow
FRONTEND_URL=https://talentflow-platform.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
# Port 8001 avoids WinError 10013 on Windows (port 8000 may be reserved).
PORT=8001
HOST=0.0.0.0

# Email delivery (production)
# Option A: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Option B: Resend
RESEND_API_KEY=
EMAIL_FROM=

# Development only: logs OTP codes when email is not configured.
# Keep false in production.
ALLOW_DEV_EMAIL_FALLBACK=false
ENVIRONMENT=production
